# Vite env vars must be prefixed with VITE_
#
# Example:
# VITE_API_BASE_URL=http://127.0.0.1:8000/api
# VITE_WS_BASE_URL=ws://127.0.0.1:8001

# Router mode: 'history' (default) or 'hash' (recommended for Tauri/Capacitor build output).
# VITE_ROUTER_MODE=hash

# Optional: GitHub repo used by /download page to list release assets (format: owner/repo)
# VITE_GITHUB_REPO=acme/work_order
