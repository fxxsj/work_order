{
  "build": {
    "beforeDevCommand": "node ./scripts/ensure-web-dev.mjs",
    "beforeBuildCommand": "node ./scripts/build-web.mjs",
    "devPath": "http://localhost:5173",
    "distDir": "../../web/dist"
  },
  "package": {
    "productName": "WorkOrder",
    "version": "0.1.0"
  },
  "tauri": {
    "windows": [
      {
        "title": "WorkOrder",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.workorder.app",
      "icon": [
        "icons/icon.ico",
        "icons/icon.icns",
        "icons/icon.png"
      ]
    },
    "updater": {
      "active": false,
      "endpoints": [
        "https://github.com/fxxsj/work_order/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": ""
    }
  }
}
